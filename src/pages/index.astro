---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Gutter from '../components/Gutter.astro';
import SectionBar from '../components/SectionBar.astro';
import Chatbot from '../components/Chatbot';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Urvash Chheda — Technical Product Manager</title>
    <meta name="description" content="Senior Technical PM building the infrastructure modern AI runs on. 12 years across data platforms, ML pipelines, and 0→1 product builds." />
  </head>
  <body>
    <Nav />

    <!-- ── HERO ────────────────────────────────────────────────────── -->
    <section class="hero">
      <Gutter label="intro" borderBottom={false}>
        <div class="hero-content">
          <p class="hero-eyebrow fade-up" style="animation-delay:0s">SENIOR TECHNICAL PRODUCT MANAGER</p>
          <h1 class="hero-h1 fade-up" style="animation-delay:0.07s">
            I build the foundations<br>
            <em class="hero-modern">modern</em> <span class="hero-ai">AI</span> runs on.
          </h1>
          <p class="hero-deck fade-up" style="animation-delay:0.14s">
            Not a PM who delegates technical decisions. Someone who reads the schema, challenges the architecture, and stays accountable to what ships.
          </p>
          <div class="fade-up" style="animation-delay:0.21s">
            <Chatbot client:load />
          </div>
        </div>
      </Gutter>
    </section>

    <!-- ── SUPERPOWER STRIP ────────────────────────────────────────── -->
    <section class="sp-strip">
      <Gutter label="pattern" borderBottom={false}>
        <div class="sp-content">
          <p class="sp-label">THE PATTERN ACROSS 12 YEARS</p>
          <p class="sp-quote">
            Every role has been a variation of the same problem:
            <em class="sp-dim"> product ambition outpacing the infrastructure it runs on.</em>
            The work is always closing that gap —
            <span class="sp-warm">without rebuilding everything from scratch.</span>
          </p>
        </div>
      </Gutter>
    </section>

    <!-- ── WORK PREVIEW ────────────────────────────────────────────── -->
    <SectionBar label="WORK" />
    <section class="work-preview">
      <Gutter label="work" borderBottom={true}>
        <div class="wi-list">

          <a href="/work/insights-service" class="wi-row">
            <div class="wi-meta">
              <span class="wi-year">2023–24</span>
              <span class="wi-tag">ML Platform · Later</span>
            </div>
            <div class="wi-body">
              <h3 class="wi-title">Insights Service</h3>
              <p class="wi-desc">Rebuilt the data layer underneath Later's analytics — one migration at a time, without stopping product.</p>
              <p class="wi-hook">The hard part wasn't the architecture. Read why.</p>
            </div>
            <div class="wi-metric">
              <span class="wi-num">4×</span>
              <span class="wi-unit">time to insight</span>
              <span class="wi-num wi-num-2">90%</span>
              <span class="wi-unit">cost reduction</span>
            </div>
          </a>

          <a href="/work/later-360" class="wi-row wi-row-border">
            <div class="wi-meta">
              <span class="wi-year">2022–23</span>
              <span class="wi-tag">Enterprise Analytics · Later</span>
            </div>
            <div class="wi-body">
              <h3 class="wi-title">Later 360</h3>
              <p class="wi-desc">Enterprise analytics for Walmart, DraftKings, Southwest. One configuration layer instead of three custom builds.</p>
              <p class="wi-hook">The reframe that changed the entire architecture.</p>
            </div>
            <div class="wi-metric">
              <span class="wi-num">4</span>
              <span class="wi-unit">enterprise clients</span>
              <span class="wi-num wi-num-2">2×</span>
              <span class="wi-unit">faster than custom</span>
            </div>
          </a>

          <a href="/work/aptean" class="wi-row wi-row-border">
            <div class="wi-meta">
              <span class="wi-year">2020–22</span>
              <span class="wi-tag">Platform Product · Aptean</span>
            </div>
            <div class="wi-body">
              <h3 class="wi-title">Embedded Analytics Platform</h3>
              <p class="wi-desc">Analytics layer across a $80M ARR SaaS portfolio — built for internal engineering teams as the customer.</p>
              <p class="wi-hook">The assumption that cost us two months.</p>
            </div>
            <div class="wi-metric">
              <span class="wi-num">$80M</span>
              <span class="wi-unit">ARR portfolio</span>
              <span class="wi-num wi-num-2">6</span>
              <span class="wi-unit">products integrated</span>
            </div>
          </a>

        </div>
      </Gutter>
    </section>

    <!-- ── PERSON ────────────────────────────────────────────────────── -->
    <SectionBar label="THE PERSON" link={{ href: "/about", text: "About" }} />
    <section class="ps-section">
      <div class="ps-g"></div>
      <div class="ps-l">
        <div class="ps-name">Urvash<br><em>Chheda.</em></div>
        <p class="ps-body">I've spent eight years as a product person who couldn't stop reading the schema.</p>
      </div>
      <div class="ps-r">
        <div class="ps-facts">
          <div class="ps-fact"><span class="ps-fk">Currently</span><span class="ps-fv">At Later</span></div>
          <div class="ps-fact"><span class="ps-fk">Building</span><span class="ps-fv">FinTrack · this site · Obsidian second brain</span></div>
          <div class="ps-fact"><span class="ps-fk">Contact</span><span class="ps-fv">urvash@hey.com · <a href="https://linkedin.com/in/urvashc" class="ps-link">LinkedIn →</a></span></div>
        </div>
      </div>
    </section>

    {/* --- Final CTA --- */}
    <section class="cta-wrap">
      <Gutter label="contact" borderBottom={false}>
        <div class="cta-inner">
          <p class="cta-headline">Want to talk?</p>
          <div class="cta-btns">
            <a href="mailto:urvash@hey.com" class="cta-btn">urvash@hey.com</a>
            <a href="https://linkedin.com/in/urvashc" target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn--outline">LinkedIn →</a>
          </div>
        </div>
      </Gutter>
    </section>

    <Footer />
  </body>
</html>

<style>
  /* ── HERO ──────────────────────────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .fade-up {
    opacity: 0;
    animation: fadeUp 0.6s cubic-bezier(0.16,1,0.3,1) forwards;
  }

  .hero {
    padding-top: 120px;
    padding-bottom: 80px;
  }

  .hero-content { max-width: 680px; }

  .hero-eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--ink-3);
    text-transform: uppercase;
    margin: 0 0 24px;
  }

  .hero-h1 {
    font-family: var(--serif);
    font-size: clamp(36px, 5vw, 58px);
    font-weight: 400;
    line-height: 1.1;
    color: var(--ink);
    margin: 0 0 24px;
  }

  .hero-modern { color: var(--ink-2); font-style: italic; }
  .hero-ai     { color: var(--red); font-style: normal; }

  .hero-deck {
    font-family: var(--sans);
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-3);
    max-width: 420px;
    margin: 0 0 40px;
  }

  /* ── SUPERPOWER STRIP ─────────────────────────────────────────── */
  .sp-strip {
    background: var(--ink);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .sp-strip :global(.g-label) { color: rgba(255,255,255,0.2); }

  .sp-content {
    padding: 64px 0;
    max-width: 640px;
  }

  .sp-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.35);
    text-transform: uppercase;
    margin: 0 0 28px;
  }

  .sp-quote {
    font-family: var(--serif);
    font-size: clamp(20px, 2.5vw, 28px);
    line-height: 1.55;
    color: #fff;
    margin: 0;
  }

  .sp-dim  { color: rgba(255, 255, 255, 0.5); font-style: italic; }
  .sp-warm { color: #e07060; }

  /* ── WORK PREVIEW ─────────────────────────────────────────────── */
  .wi-list { width: 100%; border-top: 1px solid var(--rule); }

  .wi-row {
    display: grid;
    grid-template-columns: 120px 1fr 160px;
    gap: 28px;
    padding: 40px 0;
    text-decoration: none;
    color: inherit;
    align-items: start;
    transition: opacity 0.14s;
  }

  .wi-row:hover { opacity: 0.6; }

  .wi-row-border { border-top: 1px solid var(--rule); }

  .wi-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 3px;
  }

  .wi-year {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--ink-3);
  }

  .wi-tag {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
    line-height: 1.4;
  }

  .wi-title {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 400;
    color: var(--ink);
    margin: 0 0 10px;
  }

  .wi-desc {
    font-family: var(--sans);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-3);
    margin: 0 0 12px;
  }

  .wi-hook {
    font-family: var(--sans);
    font-size: 14px;
    font-style: italic;
    color: var(--ink-2);
    margin: 0;
  }

  .wi-metric {
    display: flex;
    flex-direction: column;
    gap: 3px;
    text-align: right;
    padding-top: 2px;
    align-items: flex-end;
  }

  .wi-num {
    font-family: var(--mono);
    font-size: 22px;
    color: var(--ink);
    line-height: 1;
  }

  .wi-num-2 { margin-top: 14px; }

  .wi-unit {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
  }

  /* ── PERSON ───────────────────────────────────────────────────── */
  .ps-section {
    display: grid;
    grid-template-columns: var(--gutter) 1fr 1fr;
    border-bottom: 1px solid var(--rule);
    max-width: 1280px;
    margin-left: auto;
    margin-right: auto;
  }
  .ps-g {
    border-right: 1px solid var(--rule);
  }
  .ps-l {
    padding: 36px 40px;
    border-right: 1px solid var(--rule);
  }
  .ps-name {
    font-family: var(--serif);
    font-size: 26px;
    font-weight: 400;
    color: var(--ink);
    line-height: 1.2;
    margin-bottom: 14px;
    letter-spacing: -0.02em;
  }
  .ps-name em {
    font-style: italic;
    color: var(--ink-2);
  }
  .ps-body {
    font-size: 15px;
    color: var(--ink-3);
    line-height: 1.82;
    max-width: 320px;
  }
  .ps-r {
    padding: 36px 40px;
  }
  .ps-facts {
    display: flex;
    flex-direction: column;
  }
  .ps-fact {
    display: flex;
    gap: 14px;
    padding: 11px 0;
    border-bottom: 1px solid var(--rule);
    align-items: flex-start;
  }
  .ps-fact:last-child {
    border-bottom: none;
  }
  .ps-fk {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
    min-width: 76px;
    padding-top: 1px;
  }
  .ps-fv {
    font-size: 14px;
    color: var(--ink-2);
    line-height: 1.55;
  }
  .ps-link {
    color: var(--ink-2);
    text-decoration: none;
  }
  .ps-link:hover {
    color: var(--ink);
  }

  /* ── Final CTA ────────────────────────────────────────────────── */
  .cta-wrap {
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .cta-inner {
    padding: 64px 0 72px;
    display: flex;
    align-items: center;
    gap: 40px;
    flex-wrap: wrap;
  }
  .cta-headline {
    font-family: var(--serif);
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 400;
    color: var(--ink);
    line-height: 1;
    margin: 0;
  }
  .cta-btns {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .cta-btn {
    font-family: var(--sans);
    font-size: 14px;
    letter-spacing: 0.02em;
    background: var(--ink);
    color: var(--surface);
    border: 1px solid var(--ink);
    padding: 10px 20px;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .cta-btn:hover { opacity: 0.75; }
  .cta-btn--outline {
    background: transparent;
    color: var(--ink);
  }

  /* ── MOBILE ────────────────────────────────────────────────────── */
  @media (max-width: 780px) {
    .wi-row {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .wi-metric { text-align: left; }
  }
</style>
