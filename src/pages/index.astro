---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import Particles from '../components/Particles.astro';
import PixelReveal from '../components/PixelReveal.astro';
import Footer from '../components/Footer.astro';

const title = 'Urvash Chheda — AI Technical PM';
const description = 'AI Technical Product Manager building at the intersection of human intent and machine capability.';
---

<BaseLayout title={title} description={description} currentPage="home">
  <Fragment slot="head">
    <SEOHead title={title} description={description} />
  </Fragment>

  <Particles />

  <main class="page-home">

    <!-- ── HERO ─────────────────────────────────────────────────────── -->
    <section class="hero">
      <div class="hero-left">
        <h1 class="hero-name" id="hero-name">Urvash Chheda</h1>
        <p class="hero-role">AI Technical Product Manager</p>
        <p class="hero-tagline">I build the interface between human intent and machine capability.</p>
        <div class="hero-stats">
          <div class="stat-pill">
            <span class="stat-num">7+</span>
            <span class="stat-label">years experience</span>
          </div>
          <div class="stat-pill">
            <span class="stat-num">12+</span>
            <span class="stat-label">AI products shipped</span>
          </div>
          <div class="stat-pill">
            <span class="stat-num">3</span>
            <span class="stat-label">companies</span>
          </div>
        </div>
      </div>

      <div class="hero-right">
        <div class="hero-photo-wrap" id="photo-wrap">
          <img
            src="/images/urvash-bw.jpg"
            alt="Urvash Chheda"
            class="hero-photo"
          />
          <PixelReveal />
        </div>
      </div>
    </section>

    <!-- ── [01] SELECTED WORK ─────────────────────────────────────── -->
    <section class="section work-preview">
      <div class="section-label">
        <span class="s-bracket">[</span>01<span class="s-bracket">]</span> · SELECTED WORK
      </div>
      <div class="work-cards">
        <a href="/work/mavrck" class="work-card">
          <div class="card-tag">[AI · PRODUCT]</div>
          <div class="card-title">Mavrck AI Influencer Matching</div>
          <p class="card-desc">Reduced manual influencer vetting by 70% through semantic matching pipeline</p>
          <div class="card-foot">2023 · Mavrck</div>
        </a>
        <a href="/work/creator-intelligence" class="work-card">
          <div class="card-tag">[ML · PLATFORM]</div>
          <div class="card-title">Creator Intelligence Platform</div>
          <p class="card-desc">Built real-time creator scoring across 50M+ profiles using LLM enrichment</p>
          <div class="card-foot">2024 · LTK</div>
        </a>
      </div>
    </section>

    <!-- ── [02] CURRENTLY ─────────────────────────────────────────── -->
    <section class="section currently">
      <div class="section-label">
        <span class="s-bracket">[</span>02<span class="s-bracket">]</span> · CURRENTLY
      </div>
      <div class="currently-grid">
        <div class="currently-col">
          <div class="col-heading">Building</div>
          <div class="col-item"><span class="col-arrow">→</span>AI search at LTK</div>
          <div class="col-item"><span class="col-arrow">→</span>personal knowledge infrastructure</div>
        </div>
        <div class="currently-col">
          <div class="col-heading">Thinking about</div>
          <div class="col-item"><span class="col-arrow">→</span>ambient interfaces</div>
          <div class="col-item"><span class="col-arrow">→</span>AI x PM career paths</div>
        </div>
      </div>
    </section>

  </main>

  <Footer />

  <script>
    // ── Character assembly — name resolves char-by-char ──────────────
    const CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
    const nameEl = document.getElementById('hero-name');

    if (nameEl) {
      const original = nameEl.textContent?.trim() ?? '';
      nameEl.textContent = '';
      nameEl.setAttribute('aria-label', original);

      const spanData = [...original].map(ch => {
        const span = document.createElement('span');
        span.setAttribute('aria-hidden', 'true');
        if (ch === ' ') {
          span.innerHTML = '&nbsp;';
          span.className = 'char resolved';
        } else {
          span.textContent = CHARS[Math.floor(Math.random() * CHARS.length)];
          span.className = 'char unresolved';
        }
        nameEl.appendChild(span);
        return { span, target: ch, isSpace: ch === ' ' };
      });

      const nonSpace = spanData.filter(s => !s.isSpace);
      let resolvedIdx = 0;

      function scramble() {
        nonSpace.slice(resolvedIdx).forEach(item => {
          item.span.textContent = CHARS[Math.floor(Math.random() * CHARS.length)];
        });
        if (resolvedIdx < nonSpace.length) requestAnimationFrame(scramble);
      }

      function resolveNext() {
        if (resolvedIdx >= nonSpace.length) return;
        const item = nonSpace[resolvedIdx];
        item.span.textContent = item.target;
        item.span.className = 'char resolved';
        resolvedIdx++;
        if (resolvedIdx < nonSpace.length) setTimeout(resolveNext, 40);
      }

      setTimeout(() => {
        resolveNext();
        scramble();
      }, 300);
    }
  </script>
</BaseLayout>

<style>
  /* ── Page wrapper ─────────────────────────────────────────────────── */
  .page-home {
    position: relative;
    z-index: 1;
  }

  /* ── Section chrome ───────────────────────────────────────────────── */
  .section {
    border-top: 1px solid var(--border);
    padding: var(--section-gap) var(--pad-r) var(--section-gap) var(--pad-l);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.12em;
    margin-bottom: 1.5rem;
  }

  .s-bracket { color: var(--text-dimmer); }

  /* ── Hero layout ──────────────────────────────────────────────────── */
  .hero {
    display: flex;
    gap: 4rem;
    align-items: center;
    min-height: 100vh;
    padding: 7rem var(--pad-r) 5rem var(--pad-l);
  }

  .hero-left  { flex: 1.2; }
  .hero-right { flex: 0.8; display: flex; justify-content: flex-end; align-items: center; }

  /* ── Name ─────────────────────────────────────────────────────────── */
  .hero-name {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 4.5vw, 4.5rem);
    font-style: italic;
    font-weight: 400;
    color: var(--text);
    line-height: 1;
    margin: 0;
  }

  :global(.char.unresolved) { color: var(--text-dimmer); }
  :global(.char.resolved)   { color: var(--text); }

  /* ── Hero text ────────────────────────────────────────────────────── */
  .hero-role {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-dim);
    margin-top: 1rem;
    letter-spacing: 0.08em;
  }

  .hero-tagline {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-style: italic;
    color: var(--text);
    margin-top: 1.5rem;
    line-height: 1.5;
    max-width: 480px;
  }

  /* ── Stat pills ───────────────────────────────────────────────────── */
  .hero-stats {
    display: flex;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .stat-pill  { display: flex; flex-direction: column; gap: 0.25rem; }

  .stat-num {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    color: var(--accent);
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dim);
    letter-spacing: 0.06em;
  }

  /* ── Photo ────────────────────────────────────────────────────────── */
  .hero-photo-wrap {
    position: relative;
    width: 100%;
    max-width: 280px;
    overflow: hidden;
  }

  .hero-photo {
    width: 100%;
    display: block;
    filter: grayscale(100%) contrast(1.1);
  }

  /* ── Work cards ───────────────────────────────────────────────────── */
  .work-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .work-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: var(--surface);
    text-decoration: none;
    transition: background 0.2s ease, outline-color 0.2s ease;
    outline: 1px solid transparent;
    outline-offset: -1px;
  }

  .work-card:hover {
    background: var(--surface-2);
    outline-color: var(--accent);
  }

  .card-tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .card-title {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .card-desc {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.6;
    flex: 1;
    margin: 0;
  }

  .card-foot {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dimmer);
    margin-top: 1.25rem;
    letter-spacing: 0.04em;
  }

  /* ── Currently ────────────────────────────────────────────────────── */
  .currently-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .col-heading {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .col-item {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 2;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .col-arrow { color: var(--accent); flex-shrink: 0; }

  /* ── Mobile ───────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero {
      flex-direction: column-reverse;
      min-height: auto;
      padding-top: 6rem;
      gap: 2.5rem;
    }

    .hero-right { justify-content: flex-start; }
    .hero-photo-wrap { max-width: 200px; }
    .hero-stats { gap: 1rem; flex-wrap: wrap; }
    .work-cards { grid-template-columns: 1fr; }
    .currently-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
