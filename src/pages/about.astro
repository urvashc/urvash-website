---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import Footer from '../components/Footer.astro';

const title = 'About — Urvash Chheda';
const description = 'Product person. AI builder. Systems thinker.';
---

<BaseLayout title={title} description={description} currentPage="about">
  <Fragment slot="head">
    <SEOHead title={title} description={description} />
  </Fragment>

  <main class="page-about">

    <!-- ── PAGE HEADER ──────────────────────────────────────────────── -->
    <header class="about-header">
      <div class="page-label"><span class="s-bracket">[</span>about<span class="s-bracket">]</span></div>
      <h1 class="about-headline">Who I am.</h1>
      <p class="about-sub">Product person. AI builder. Systems thinker. Occasional overengineer.</p>
    </header>

    <!-- ── [01] WHO I AM ────────────────────────────────────────────── -->
    <section class="section">
      <div class="section-label">
        <span class="s-bracket">[</span>01<span class="s-bracket">]</span> · WHO I AM
      </div>
      <div class="bio">
        <p class="bio-p">I've spent 8 years at companies where the data infrastructure was always slightly behind what the product needed it to be. That specific tension — product ambition outpacing its own foundation — is the problem I keep getting hired to solve. At this point I think I just find it interesting.</p>
        <p class="bio-p">My technical depth is real but specific. I can read a dbt model, trace a dependency graph, write SQL well enough to validate a data model from the query layer, review an API contract and spot where it'll break at scale. What I do with that is make the technical conversation faster and the decisions cheaper — without anyone needing to translate in the room.</p>
      </div>
    </section>

    <!-- ── [02] HOW I WORK ───────────────────────────────────────────── -->
    <section class="section">
      <div class="section-label">
        <span class="s-bracket">[</span>02<span class="s-bracket">]</span> · HOW I WORK
      </div>
      <div class="items-grid">
        <div class="work-item">
          <div class="item-label">[start with why]</div>
          <p class="item-desc">Before writing a spec, I map the problem. What are users actually doing? What's the system incentive? What breaks if this is wrong?</p>
        </div>
        <div class="work-item">
          <div class="item-label">[prototype to think]</div>
          <p class="item-desc">I use code and data to think. A quick SQL query or a rough Retool dashboard often clarifies requirements faster than a week of meetings.</p>
        </div>
        <div class="work-item">
          <div class="item-label">[write to decide]</div>
          <p class="item-desc">If I can't explain a decision in writing, I haven't made it yet. I write to sharpen thinking, not to document after the fact.</p>
        </div>
        <div class="work-item">
          <div class="item-label">[ship and learn]</div>
          <p class="item-desc">Perfect is the enemy of shipped. I bias toward getting something real in front of users, measuring it, and iterating — not waiting for certainty.</p>
        </div>
      </div>
    </section>

    <!-- ── [03] WHAT I BUILD ─────────────────────────────────────────── -->
    <section class="section">
      <div class="section-label">
        <span class="s-bracket">[</span>03<span class="s-bracket">]</span> · WHAT I BUILD
      </div>
      <div class="items-grid">
        <div class="work-item">
          <div class="item-label">[AI products]</div>
          <p class="item-desc">Matching engines, recommendation systems, search pipelines, content classifiers. Usually the glue between an LLM and a database somebody forgot to document.</p>
        </div>
        <div class="work-item">
          <div class="item-label">[data products]</div>
          <p class="item-desc">Things that turn messy event streams into decisions someone can act on. Dashboards that don't lie. Metrics that don't gaslight.</p>
        </div>
        <div class="work-item">
          <div class="item-label">[0→1 infrastructure]</div>
          <p class="item-desc">The boring important stuff: auth, APIs, background jobs, the Supabase schema that holds it all together. I like building foundations.</p>
        </div>
      </div>
    </section>

    <!-- ── [04] WHERE I COME FROM ────────────────────────────────────── -->
    <section class="section">
      <div class="section-label">
        <span class="s-bracket">[</span>04<span class="s-bracket">]</span> · WHERE I COME FROM
      </div>
      <div class="timeline">
        <div class="tl-item">
          <div class="tl-date">2022–present</div>
          <div class="tl-content">
            <span class="tl-company">Later (now Mavrck)</span> — Senior PM, Analytics &amp; Data Engineering. 3 teams, ML platform, reporting infrastructure.
          </div>
        </div>
        <div class="tl-item">
          <div class="tl-date">2020–2022</div>
          <div class="tl-content">
            <span class="tl-company">Aptean</span> — Product Manager. Managed data integrations for 10+ acquisitions. $80M+ ARR.
          </div>
        </div>
        <div class="tl-item">
          <div class="tl-date">Earlier</div>
          <div class="tl-content">
            <span class="tl-company">Bushel</span> — Data PM. Built analytics platform from scratch. Led enterprise data warehouse migration to GCP.
          </div>
        </div>
        <div class="tl-item">
          <div class="tl-date">Earlier</div>
          <div class="tl-content">
            <span class="tl-company">MyCrop Technologies</span> — Founding PM. First product hire at an AgTech startup. 0 to global launch.
          </div>
        </div>
        <div class="tl-item">
          <div class="tl-date">Education</div>
          <div class="tl-content">M.S. Information Systems, UMD Smith · B.Tech CS, NMIMS Mumbai.</div>
        </div>
      </div>
    </section>

    <!-- ── [05] SIGNAL TRACES ────────────────────────────────────────── -->
    <section class="section">
      <div class="section-label">
        <span class="s-bracket">[</span>05<span class="s-bracket">]</span> · SIGNAL TRACES
      </div>
      <p class="graphs-sub">Live data about how I work — from my GitHub and Obsidian knowledge graph.</p>
      <div class="graphs-row">
        <!-- GitHub heatmap -->
        <div class="graph-panel">
          <div class="graph-label">GITHUB · COMMITS</div>
          <canvas id="github-heatmap" class="graph-canvas" aria-label="GitHub contribution heatmap"></canvas>
        </div>
        <!-- Obsidian vault graph -->
        <div class="graph-panel" id="vault-panel">
          <div class="graph-label">OBSIDIAN · VAULT GRAPH</div>
          <canvas
            id="vault-graph"
            class="graph-canvas graph-canvas--tall"
            aria-label="Obsidian vault graph — structural data only, no content exposed"
            title="vault graph — structural data only, no content exposed"
          ></canvas>
        </div>
      </div>
    </section>

  </main>

  <Footer />

  <!-- D3 from CDN for vault graph -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>

  <script>
    const isDark = () => document.documentElement.getAttribute('data-theme') !== 'light';

    // ── GitHub heatmap ───────────────────────────────────────────────
    const WEEKS = 52, DAYS = 7, GAP = 2, CELL = 10;

    function countToLevel(n: number): number {
      if (n === 0) return 0;
      if (n <= 2)  return 1;
      if (n <= 5)  return 2;
      if (n <= 10) return 3;
      return 4;
    }

    function cellColor(v: number): string {
      if (isDark()) {
        return (['#1a1a18','#003d1f','#006633','#00994d','#00ff88'] as const)[v] ?? '#1a1a18';
      }
      return (['#dddbd4','#c3e8d0','#7dcfa1','#2da862','#00994d'] as const)[v] ?? '#dddbd4';
    }

    function renderHeatmap(canvas: HTMLCanvasElement, grid: number[][]) {
      const ctx = canvas.getContext('2d')!;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      grid.forEach((week, w) =>
        week.forEach((v, d) => {
          ctx.fillStyle = cellColor(v);
          ctx.fillRect(w * (CELL + GAP), d * (CELL + GAP), CELL, CELL);
        })
      );
    }

    async function initHeatmap() {
      const canvas = document.getElementById('github-heatmap') as HTMLCanvasElement;
      if (!canvas) return;
      canvas.width  = WEEKS * (CELL + GAP);
      canvas.height = DAYS  * (CELL + GAP);

      // Draw grey fallback immediately
      const fallback = Array.from({ length: WEEKS }, () => Array(DAYS).fill(0));
      renderHeatmap(canvas, fallback);

      try {
        const res = await fetch('/api/github-activity');
        if (!res.ok) throw new Error('non-200');
        const { weeks } = await res.json() as {
          weeks: { contributionDays: { contributionCount: number }[] }[]
        };

        const grid = weeks.slice(0, WEEKS).map(week =>
          week.contributionDays.slice(0, DAYS).map(d => countToLevel(d.contributionCount))
        );
        // Pad if fewer than 52 weeks returned
        while (grid.length < WEEKS) grid.push(Array(DAYS).fill(0));

        renderHeatmap(canvas, grid);
      } catch {
        // fallback already rendered
      }
    }

    // ── Vault graph ──────────────────────────────────────────────────
    function nodeColor(folder: string): string {
      const dark = isDark();
      const map: Record<string, [string, string]> = {
        '01-projects': ['#00ff88', '#00994d'],
        '02-decisions': ['#4488ff', '#2266cc'],
        '03-learnings': ['#ff8844', '#cc5522'],
        '04-interviews': ['#888880', '#5a5a54'],
      };
      const pair = map[folder];
      if (pair) return dark ? pair[0] : pair[1];
      return dark ? '#888880' : '#5a5a54';
    }

    function drawGraph(
      canvas: HTMLCanvasElement,
      nodes: { id: number; folder: string; degree: number; x?: number; y?: number }[],
      links: { source: number | { id: number; x: number; y: number }; target: number | { id: number; x: number; y: number } }[]
    ) {
      const d3 = (window as any).d3;
      const W = canvas.width, H = canvas.height;
      const ctx = canvas.getContext('2d')!;

      const sim = d3.forceSimulation(nodes)
        .force('charge', d3.forceManyBody().strength(-80))
        .force('link', d3.forceLink(links).id((d: any) => d.id).distance(40))
        .force('center', d3.forceCenter(W / 2, H / 2))
        .stop();

      sim.tick(200);

      ctx.clearRect(0, 0, W, H);

      const linkColor = isDark() ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
      links.forEach(l => {
        const src = typeof l.source === 'object' ? l.source : nodes[l.source as number];
        const tgt = typeof l.target === 'object' ? l.target : nodes[l.target as number];
        if (!src || !tgt) return;
        ctx.beginPath();
        ctx.moveTo(src.x!, src.y!);
        ctx.lineTo(tgt.x!, tgt.y!);
        ctx.strokeStyle = linkColor;
        ctx.lineWidth = 1;
        ctx.stroke();
      });

      nodes.forEach(n => {
        const r = Math.sqrt(n.degree) * 2 + 2;
        ctx.beginPath();
        ctx.arc(n.x!, n.y!, r, 0, Math.PI * 2);
        ctx.fillStyle = nodeColor(n.folder);
        ctx.fill();
      });
    }

    function placeholderGraph() {
      const folders = ['01-projects','02-decisions','03-learnings','04-interviews'];
      return {
        nodes: Array.from({ length: 10 }, (_, i) => ({
          id: i, folder: folders[i % 4], degree: Math.floor(Math.random() * 5) + 1,
        })),
        links: Array.from({ length: 12 }, () => ({
          source: Math.floor(Math.random() * 10),
          target: Math.floor(Math.random() * 10),
        })),
      };
    }

    async function initVaultGraph() {
      const canvas = document.getElementById('vault-graph') as HTMLCanvasElement;
      if (!canvas || typeof (window as any).d3 === 'undefined') return;
      canvas.width  = canvas.offsetWidth  || 400;
      canvas.height = canvas.offsetHeight || 300;

      let nodes: any[], links: any[];
      try {
        const res = await fetch('/api/vault-graph');
        if (!res.ok) throw new Error('non-200');
        ({ nodes, links } = await res.json());
        if (!nodes?.length) throw new Error('empty');
      } catch {
        ({ nodes, links } = placeholderGraph());
      }

      drawGraph(canvas, nodes, links);
    }

    // Run after D3 CDN script and layout are ready
    window.addEventListener('load', () => {
      initHeatmap();
      initVaultGraph();
    });
  </script>
</BaseLayout>

<style>
  /* ── Page wrapper ─────────────────────────────────────────────────── */
  .page-about { position: relative; z-index: 1; }

  .section {
    border-top: 1px solid var(--border);
    padding: var(--section-gap) var(--pad-r) var(--section-gap) var(--pad-l);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.12em;
    margin-bottom: 1.5rem;
  }

  .s-bracket { color: var(--text-dimmer); }

  /* ── Header ───────────────────────────────────────────────────────── */
  .about-header {
    padding: 9rem var(--pad-r) 3.5rem var(--pad-l);
    border-bottom: 1px solid var(--border);
  }

  .page-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.12em;
    margin-bottom: 1.5rem;
  }

  .about-headline {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 3vw, 3rem);
    font-style: italic;
    font-weight: 400;
    color: var(--text);
    line-height: 1.1;
    margin: 0;
  }

  .about-sub {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-dim);
    margin-top: 0.75rem;
    line-height: 1.6;
  }

  /* ── Bio ──────────────────────────────────────────────────────────── */
  .bio { max-width: 600px; }

  .bio-p {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-dim);
    line-height: 1.9;
    margin: 0 0 1.25rem;
  }
  .bio-p:last-child { margin-bottom: 0; }

  /* ── How I work / What I build items ─────────────────────────────── */
  .items-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 3rem;
  }

  .work-item { margin-bottom: 2rem; }

  .item-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--accent);
    margin-bottom: 0.4rem;
    letter-spacing: 0.02em;
  }

  .item-desc {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.7;
    margin: 0;
  }

  /* ── Timeline ─────────────────────────────────────────────────────── */
  .timeline { display: flex; flex-direction: column; gap: 1.5rem; }

  .tl-item {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .tl-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dimmer);
    min-width: 120px;
    padding-top: 0.1rem;
    flex-shrink: 0;
  }

  .tl-content {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.6;
    padding-left: 1.5rem;
    border-left: 1px dotted var(--border);
  }

  .tl-company {
    color: var(--text);
    font-weight: 500;
  }

  /* ── Graphs ───────────────────────────────────────────────────────── */
  .graphs-sub {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
  }

  .graphs-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .graph-panel {
    background: var(--surface);
    padding: 1.75rem;
  }

  .graph-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .graph-canvas {
    display: block;
    width: 100%;
    height: 100px;
    image-rendering: pixelated;
  }

  .graph-canvas--tall { height: 300px; }

  /* ── Responsive ───────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .items-grid    { grid-template-columns: 1fr; }
    .graphs-row    { grid-template-columns: 1fr; }
    .about-header  { padding-top: 7rem; }
  }
</style>
