---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Footer from '../../components/Footer.astro';

const title = 'Work — Urvash Chheda';
const description = 'AI products, platforms, and the occasional prototype that made it to prod.';
---

<BaseLayout title={title} description={description} currentPage="work">
  <Fragment slot="head">
    <SEOHead title={title} description={description} />
  </Fragment>

  <main class="page-work">

    <!-- ── PAGE HEADER ──────────────────────────────────────────────── -->
    <header class="work-header">
      <div class="page-label"><span class="s-bracket">[</span>work<span class="s-bracket">]</span></div>
      <h1 class="work-headline">Things I've shipped.</h1>
      <p class="work-sub">AI products, platforms, and the occasional prototype that made it to prod.</p>
    </header>

    <!-- ── [01] CASE STUDIES ─────────────────────────────────────────── -->
    <section class="section case-studies">
      <div class="section-label">
        <span class="s-bracket">[</span>01<span class="s-bracket">]</span> · CASE STUDIES
      </div>

      <!-- Card 1 — Insights Service -->
      <a href="/work/insights-service" class="cs-card cs-card--linked">
        <div class="cs-company">LATER · 2023–24</div>
        <div class="cs-title">Insights Service</div>
        <p class="cs-desc">Four product teams were independently building SageMaker integrations for the same 10+ ML models. Built a centralized serving layer — DynamoDB predictions store, BigQuery replica via Pub/Sub — that eliminated ~100 sprints of duplicated engineering and fixed six-months-stale influence scores affecting 200+ active campaigns.</p>
        <div class="cs-tags">
          <span class="cs-tag">[ML PLATFORM]</span>
          <span class="cs-tag">[AWS]</span>
          <span class="cs-tag">[DATA INFRASTRUCTURE]</span>
        </div>
        <div class="cs-metrics">4× faster queries · 90% cost reduction · 10 wk to production</div>
        <div class="cs-cta">Read case study →</div>
      </a>

      <!-- Card 2 — Later 360 -->
      <a href="/work/later-360" class="cs-card cs-card--linked">
        <div class="cs-company">LATER · 2022–23</div>
        <div class="cs-title">Later 360</div>
        <p class="cs-desc">Led a 6-month rebuild of Later's analytics backend — from a shared product DB with 1-day-stale data to a dedicated analytics service with OLAP star schema and a CDC binlog pipeline. Data freshness went from 24 hours to 5–10 minutes. Unlocked the enterprise segment.</p>
        <div class="cs-tags">
          <span class="cs-tag">[DATA INFRASTRUCTURE]</span>
          <span class="cs-tag">[ANALYTICS]</span>
          <span class="cs-tag">[ENTERPRISE]</span>
        </div>
        <div class="cs-metrics">5 enterprise clients closed · 60%+ SQL tickets reduced</div>
        <div class="cs-cta">Read case study →</div>
      </a>

    </section>

    <!-- ── [02] CAREER ───────────────────────────────────────────────── -->
    <section class="section career-section">
      <div class="section-label">
        <span class="s-bracket">[</span>02<span class="s-bracket">]</span> · CAREER
      </div>

      <div class="cs-card">
        <div class="cs-company">LATER (FORMERLY MAVRCK) · FEB 2023–PRESENT</div>
        <div class="career-title">Senior PM, Data &amp; Analytics</div>
        <p class="cs-desc">Leading data platform transformation, ML operationalization, and revenue-generating analytics products.</p>
      </div>

      <div class="cs-card">
        <div class="cs-company">BUSHEL, INC · JUNE 2021–DEC 2022</div>
        <div class="career-title">Product Manager, Data Analytics</div>
        <p class="cs-desc">Built analytics platform 0→1; migrated enterprise data warehouse to GCP, cutting downtime 75%.</p>
      </div>

      <div class="cs-card">
        <div class="cs-company">APTEAN, INC. · FEB 2020–JUNE 2021</div>
        <div class="career-title">Associate PM, M&amp;A Integrations</div>
        <p class="cs-desc">Managed data integrations across 10+ acquisitions and 30+ product lines on $80M+ ARR.</p>
      </div>

      <div class="cs-card">
        <div class="cs-company">MYCROP TECHNOLOGIES · JUNE 2016–JULY 2018</div>
        <div class="career-title">Founding Product Manager</div>
        <p class="cs-desc">0→1 SaaS for precision agriculture — 100% YoY growth, 2,000+ global users.</p>
      </div>

    </section>

    <!-- ── [03] TOOLS I ACTUALLY USE ─────────────────────────────────── -->
    <section class="section tools-section">
      <div class="section-label">
        <span class="s-bracket">[</span>03<span class="s-bracket">]</span> · TOOLS I ACTUALLY USE
      </div>

      <div class="tools-grid">
        <div class="tool-card">
          <div class="tool-name">Claude</div>
          <p class="tool-desc">Because the API call is faster than a meeting, and the hard part is the eval layer — figuring out when the model is confidently wrong.</p>
        </div>
        <div class="tool-card">
          <div class="tool-name">Supabase</div>
          <p class="tool-desc">Every schema decision is a product decision. I want to be the one making it, not approving it after the fact.</p>
        </div>
        <div class="tool-card">
          <div class="tool-name">Obsidian</div>
          <p class="tool-desc">Running decision log across 8 years of product calls. Not a productivity trick — the pattern recognition starts working when the archive gets long enough.</p>
        </div>
        <div class="tool-card">
          <div class="tool-name">dbt + BigQuery</div>
          <p class="tool-desc">The stack I build on, not just adjacent to. If I'm speccing a data product and I haven't touched the model, the spec is incomplete.</p>
        </div>
        <div class="tool-card">
          <div class="tool-name">Linear</div>
          <p class="tool-desc">I keep an explicit dropped-items list every sprint. A dropped item that isn't documented is a commitment that doesn't exist.</p>
        </div>
        <div class="tool-card">
          <div class="tool-name">SageMaker</div>
          <p class="tool-desc">I can't review a model's business impact without seeing the endpoint latency and prediction volume directly.</p>
        </div>
        <div class="tool-card">
          <div class="tool-name">GitHub</div>
          <p class="tool-desc">Read access isn't optional if I'm accountable for what ships. I run PR review sessions with the team — not to gatekeep, to understand.</p>
        </div>
      </div>
    </section>

    <!-- ── [04] WORKING PRINCIPLES ────────────────────────────────────── -->
    <section class="section principles-section">
      <div class="section-label">
        <span class="s-bracket">[</span>04<span class="s-bracket">]</span> · WORKING PRINCIPLES
      </div>

      <div class="principles-grid">
        <div class="principle-card">
          <div class="principle-num">01</div>
          <div class="principle-title">Say no before it gets expensive</div>
          <p class="principle-body">The cost of a wrong decision compounds with time. Being wrong fast and cheap beats being right slowly and expensively. That requires willingness to kill work I personally championed.</p>
        </div>
        <div class="principle-card">
          <div class="principle-num">02</div>
          <div class="principle-title">Read the actual data</div>
          <p class="principle-body">I don't trust dashboards I haven't traced back to a source. Decisions about data products need to be made from raw data, not summaries of summaries. The signal lives in the table.</p>
        </div>
        <div class="principle-card">
          <div class="principle-num">03</div>
          <div class="principle-title">The architecture is the roadmap</div>
          <p class="principle-body">Most product constraints aren't strategic — they're structural. Understanding the data model tells you more about what's actually possible than any discovery session.</p>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Page wrapper ─────────────────────────────────────────────────── */
  .page-work {
    position: relative;
    z-index: 1;
  }

  /* ── Section chrome ───────────────────────────────────────────────── */
  .section {
    border-top: 1px solid var(--border);
    padding: var(--section-gap) var(--pad-r) var(--section-gap) var(--pad-l);
  }

  .s-bracket { color: var(--text-dimmer); }

  /* ── Page header ──────────────────────────────────────────────────── */
  .work-header {
    padding: 9rem var(--pad-r) 3.5rem var(--pad-l);
    border-bottom: 1px solid var(--border);
    text-align: right;
  }

  .page-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.12em;
    margin-bottom: 1.5rem;
  }

  .work-headline {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 3vw, 3rem);
    font-style: italic;
    font-weight: 400;
    color: var(--text);
    line-height: 1.1;
    margin: 0;
  }

  .work-sub {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-dim);
    margin-top: 0.75rem;
    line-height: 1.6;
  }

  /* ── Case study cards ─────────────────────────────────────────────── */
  .case-studies {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cs-card {
    display: block;
    padding: 2rem;
    border: 1px solid var(--border);
    background: var(--surface);
    margin-bottom: 1px;
    text-decoration: none;
    color: inherit;
    border-left-width: 1px;
    transition: border-left-color 0.2s ease, border-left-width 0.2s ease, padding-left 0.2s ease;
  }

  .cs-card--linked:hover {
    border-left: 2px solid var(--accent);
    padding-left: calc(2rem - 2px);
  }

  .cs-company {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dimmer);
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .cs-title {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.3;
  }

  .cs-desc {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.7;
    margin-top: 0.75rem;
    max-width: 600px;
    margin-bottom: 0;
  }

  .cs-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .cs-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-dim);
    border: 1px solid var(--border);
    padding: 0.2rem 0.5rem;
    letter-spacing: 0.06em;
  }

  .cs-cta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    margin-top: 1.25rem;
  }

  .cs-cta--dim {
    color: var(--text-dimmer);
  }

  .cs-metrics {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dimmer);
    letter-spacing: 0.04em;
    margin-top: 0.75rem;
  }

  /* ── Career section ───────────────────────────────────────────────── */
  .career-title {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 400;
    color: var(--text);
    margin-top: 0.25rem;
  }

  /* ── Tools section ────────────────────────────────────────────────── */
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--border);
    border-left: 1px solid var(--border);
  }

  .tool-card {
    background: var(--surface);
    padding: 1.25rem;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .tool-name {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .tool-desc {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.7;
  }

  /* ── Principles section ───────────────────────────────────────────── */
  .principles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .principle-card {
    background: var(--surface);
    padding: 1.25rem;
  }

  .principle-num {
    font-family: var(--font-serif);
    font-size: 3rem;
    color: var(--text-dimmer);
    margin-bottom: 0.75rem;
    line-height: 1;
  }

  .principle-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .principle-body {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.7;
  }

  /* ── Responsive ───────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .tools-grid { grid-template-columns: repeat(2, 1fr); }
    .principles-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .tools-grid { grid-template-columns: 1fr; }
    .principles-grid { grid-template-columns: 1fr; }
    .work-header { padding-top: 7rem; }
  }
</style>
