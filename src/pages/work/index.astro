---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Footer from '../../components/Footer.astro';

const title = 'Work — Urvash Chheda';
const description = 'AI products, platforms, and the occasional prototype that made it to prod.';
---

<BaseLayout title={title} description={description} currentPage="work">
  <Fragment slot="head">
    <SEOHead title={title} description={description} />
  </Fragment>

  <main class="page-work">

    <!-- ── PAGE HEADER ──────────────────────────────────────────────── -->
    <header class="work-header">
      <div class="page-label"><span class="s-bracket">[</span>work<span class="s-bracket">]</span></div>
      <h1 class="work-headline">Things I've shipped.</h1>
      <p class="work-sub">AI products, platforms, and the occasional prototype that made it to prod.</p>
    </header>

    <!-- ── [01] CASE STUDIES ─────────────────────────────────────────── -->
    <section class="section case-studies">
      <div class="section-label">
        <span class="s-bracket">[</span>01<span class="s-bracket">]</span> · CASE STUDIES
      </div>

      <!-- Card 1 — Insights Service -->
      <a href="/work/insights-service" class="cs-card cs-card--linked">
        <div class="cs-company">LATER · 2023–24</div>
        <div class="cs-title">Insights Service</div>
        <p class="cs-desc">Four product teams were independently building SageMaker integrations for the same 10+ ML models. Built a centralized serving layer — DynamoDB predictions store, BigQuery replica via Pub/Sub — that eliminated ~100 sprints of duplicated engineering and fixed six-months-stale influence scores affecting 200+ active campaigns.</p>
        <div class="cs-tags">
          <span class="cs-tag">[ML PLATFORM]</span>
          <span class="cs-tag">[AWS]</span>
          <span class="cs-tag">[DATA INFRASTRUCTURE]</span>
        </div>
        <div class="cs-metrics">4× faster queries · 90% cost reduction · 10 wk to production</div>
        <div class="cs-cta">Read case study →</div>
      </a>

      <!-- Card 2 — Later 360 -->
      <a href="/work/later-360" class="cs-card cs-card--linked">
        <div class="cs-company">LATER · 2022–23</div>
        <div class="cs-title">Later 360</div>
        <p class="cs-desc">Led a 6-month rebuild of Later's analytics backend — from a shared product DB with 1-day-stale data to a dedicated analytics service with OLAP star schema and a CDC binlog pipeline. Data freshness went from 24 hours to 5–10 minutes. Unlocked the enterprise segment.</p>
        <div class="cs-tags">
          <span class="cs-tag">[DATA INFRASTRUCTURE]</span>
          <span class="cs-tag">[ANALYTICS]</span>
          <span class="cs-tag">[ENTERPRISE]</span>
        </div>
        <div class="cs-metrics">5 enterprise clients closed · 60%+ SQL tickets reduced</div>
        <div class="cs-cta">Read case study →</div>
      </a>

    </section>

    <!-- ── [02] TECHNICAL STACK ──────────────────────────────────────── -->
    <section class="section stack-section">
      <div class="section-label">
        <span class="s-bracket">[</span>02<span class="s-bracket">]</span> · TECHNICAL STACK
      </div>
      <p class="stack-desc">Tools I reach for and when I use them.</p>

      <div class="stack-grid">
        <div class="stack-card">
          <div class="stack-cat">AI / ML</div>
          <div class="stack-items">LLMs (GPT-4, Claude), embeddings, vector search (Pinecone, pgvector), fine-tuning</div>
        </div>
        <div class="stack-card">
          <div class="stack-cat">Data</div>
          <div class="stack-items">Python, SQL, dbt, Kafka, Spark, Airflow</div>
        </div>
        <div class="stack-card">
          <div class="stack-cat">Product</div>
          <div class="stack-items">Linear, Figma, Notion, Retool, Amplitude</div>
        </div>
        <div class="stack-card">
          <div class="stack-cat">Backend</div>
          <div class="stack-items">Node.js, FastAPI, Supabase, PostgreSQL, Redis</div>
        </div>
        <div class="stack-card">
          <div class="stack-cat">Frontend</div>
          <div class="stack-items">React, Astro, TypeScript, Tailwind</div>
        </div>
        <div class="stack-card">
          <div class="stack-cat">Infrastructure</div>
          <div class="stack-items">Vercel, AWS, Docker, GitHub Actions</div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Page wrapper ─────────────────────────────────────────────────── */
  .page-work {
    position: relative;
    z-index: 1;
  }

  /* ── Section chrome ───────────────────────────────────────────────── */
  .section {
    border-top: 1px solid var(--border);
    padding: var(--section-gap) var(--pad-r) var(--section-gap) var(--pad-l);
  }

  .s-bracket { color: var(--text-dimmer); }

  /* ── Page header ──────────────────────────────────────────────────── */
  .work-header {
    padding: 9rem var(--pad-r) 3.5rem var(--pad-l);
    border-bottom: 1px solid var(--border);
  }

  .page-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.12em;
    margin-bottom: 1.5rem;
  }

  .work-headline {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 3vw, 3rem);
    font-style: italic;
    font-weight: 400;
    color: var(--text);
    line-height: 1.1;
    margin: 0;
  }

  .work-sub {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-dim);
    margin-top: 0.75rem;
    line-height: 1.6;
  }

  /* ── Case study cards ─────────────────────────────────────────────── */
  .case-studies {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cs-card {
    display: block;
    padding: 2rem;
    border: 1px solid var(--border);
    background: var(--surface);
    margin-bottom: 1px;
    text-decoration: none;
    color: inherit;
    border-left-width: 1px;
    transition: border-left-color 0.2s ease, border-left-width 0.2s ease, padding-left 0.2s ease;
  }

  .cs-card--linked:hover {
    border-left: 2px solid var(--accent);
    padding-left: calc(2rem - 2px);
  }

  .cs-company {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dimmer);
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .cs-title {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.3;
  }

  .cs-desc {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.7;
    margin-top: 0.75rem;
    max-width: 600px;
    margin-bottom: 0;
  }

  .cs-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .cs-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-dim);
    border: 1px solid var(--border);
    padding: 0.2rem 0.5rem;
    letter-spacing: 0.06em;
  }

  .cs-cta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    margin-top: 1.25rem;
  }

  .cs-cta--dim {
    color: var(--text-dimmer);
  }

  .cs-metrics {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dimmer);
    letter-spacing: 0.04em;
    margin-top: 0.75rem;
  }

  /* ── Stack section ────────────────────────────────────────────────── */
  .stack-desc {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
  }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .stack-card {
    background: var(--surface);
    padding: 1.25rem;
  }

  .stack-cat {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .stack-items {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    line-height: 1.8;
  }

  /* ── Responsive ───────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .stack-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .stack-grid { grid-template-columns: 1fr; }
    .work-header { padding-top: 7rem; }
  }
</style>
