---
<footer class="site-footer">
  <span class="footer-copy">© 2026 Urvash Chheda</span>
  <div class="footer-links">
    <a href="mailto:me@urvash.com" class="footer-link">email</a>
    <span class="footer-sep">·</span>
    <a href="https://linkedin.com/in/urvashchheda" class="footer-link" target="_blank" rel="noopener noreferrer">linkedin</a>
    <span class="footer-sep">·</span>
    <a href="https://github.com/urvashc" class="footer-link" target="_blank" rel="noopener noreferrer">github</a>
    <span class="footer-sep">·</span>
    <button class="footer-link footer-ask" id="footer-ask-btn">ask me</button>
  </div>
</footer>

<style>
  .site-footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    flex-wrap: nowrap;
    padding: 1.5rem var(--pad-r) 1.5rem var(--pad-l);
    background: transparent;
    border-top: 1px solid var(--border);
  }

  /* Gradient fade so content scrolls under cleanly */
  .site-footer::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    top: -3rem;
    background: linear-gradient(to top, var(--bg) 40%, transparent);
    z-index: -1;
    pointer-events: none;
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dimmer);
    letter-spacing: 0.04em;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-link {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.06em;
    transition: color 0.2s ease;
  }

  .footer-link:hover { color: var(--accent); }

  .footer-sep {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dimmer);
    user-select: none;
  }

  .footer-ask {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
  }
</style>

<script>
  document.getElementById('footer-ask-btn')?.addEventListener('click', () => {
    document.getElementById('chat-trigger')?.click();
  });
</script>
