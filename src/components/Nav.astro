---
interface Props {
  current?: 'home' | 'work' | 'about';
}
const { current } = Astro.props;
---
<a href="#main-content" class="skip-nav">Skip to content</a>
<nav aria-label="Main navigation">
  <div class="nav-inner">
    <div class="nav-g"></div>
    <a href="/" class="nav-logo">UC</a>
    <div class="nav-links">
      <a href="/" class={`nav-link${current === 'home' ? ' active' : ''}`}>home</a>
      <a href="/work" class={`nav-link${current === 'work' ? ' active' : ''}`}>work</a>
      <a href="/about" class={`nav-link${current === 'about' ? ' active' : ''}`}>about</a>
      <button class="nav-link nav-ask" id="js-ask-btn" type="button">
        <span class="nav-dot"></span>ask me
      </button>
    </div>
    <div class="nav-photo" aria-hidden="true">
      <slot name="photo">
        <span class="nav-init">UC</span>
      </slot>
    </div>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: rgba(250,250,248,0.95);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--rule);
  }
  .nav-inner {
    display: grid;
    grid-template-columns: var(--gutter) 1fr auto auto;
    align-items: center;
    height: 50px;
  }
  .nav-g {
    border-right: 1px solid var(--rule);
    height: 100%;
  }
  .nav-logo {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
    padding-left: 22px;
    text-decoration: none;
  }
  .nav-links {
    display: flex;
    align-items: stretch;
    height: 100%;
  }
  .nav-link {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
    letter-spacing: 0.05em;
    padding: 0 18px;
    cursor: pointer;
    transition: color 0.14s;
    text-transform: lowercase;
    border: none;
    border-left: 1px solid var(--rule);
    background: none;
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--ink);
  }
  .nav-ask {
    color: var(--ink);
    font-weight: 500;
    gap: 7px;
  }
  .nav-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-available);
    box-shadow: 0 0 0 2px rgba(34,197,94,0.2);
    flex-shrink: 0;
  }
  .nav-photo {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 16px;
    border-left: 1px solid var(--rule);
    height: 100%;
  }
  .nav-init {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--surface-3);
    border: 1px solid var(--rule);
    font-family: var(--serif);
    font-size: 10px;
    font-style: italic;
    color: var(--ink-4);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  @media (max-width: 780px) {
    .nav-inner {
      grid-template-columns: 1fr auto auto;
      padding: 0 16px;
    }
    .nav-g { display: none; }
    .nav-logo { padding-left: 0; }
  }
</style>
<script>
  document.getElementById('js-ask-btn')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('chat:open', { detail: { seed: '' } }));
  });
</script>
